{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "^/*": [
        "./src/bot/*"
      ],
      "@videre-api/*": [
        "../videre-api/src/*"
      ]
    },
    "types": [
      "@cloudflare/workers-types",
      "node"
    ]
  },
  "include": [
    "src",
    "../videre-api/src"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test"
  ]
}
